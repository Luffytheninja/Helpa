,"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from 'react';\r\nimport { TopBar, StickyIcon } from '../../components/ui';\r\nimport { ICONS } from '../../constants';\r\nimport { useHaptics } from '../../hooks/useHaptics';\r\nimport { MdSavings, MdCheckCircle, MdOutboxSharp, MdCardGiftcard, MdLock, MdUndo, MdArrowForward, MdCheck } from 'react-icons/md';\r\n\r\nconst TRANSACTIONS = [\r\n  { id: 't1', type: 'credit', icon: MdLock,         desc: 'Escrow funded ΓÇö Kitchen Sink', amount: '+Γéª15,000', status: 'Pending',   date: 'Today, 10:03 AM' },\r\n  { id: 't2', type: 'credit', icon: MdCheckCircle,  desc: 'Payment released ΓÇö AC Service', amount: '+Γéª22,000', status: 'Completed', date: 'Yesterday' },\r\n  { id: 't3', type: 'debit',  icon: MdOutboxSharp,  desc: 'Withdrawal to GTBank',          amount: '-Γéª30,000', status: 'Processed', date: 'Mar 3' },\r\n  { id: 't4', type: 'credit', icon: MdCardGiftcard, desc: 'Referral bonus ΓÇö Kola joined',  amount: '+Γéª300',    status: 'Completed', date: 'Mar 2' },\r\n  { id: 't5', type: 'debit',  icon: MdSavings,      desc: 'Escrow funded ΓÇö Cleaning job', amount: '-Γéª18,000', status: 'Pending',   date: 'Mar 1' },\r\n  { id: 't6', type: 'credit', icon: MdUndo,         desc: 'Refund ΓÇö Disputed job #0042',  amount: '+Γéª18,000', status: 'Refunded',  date: 'Feb 28' },\r\n];\r\n\r\nconst FILTER_TABS = ['All', 'Earned', 'Spent', 'Pending'];\r\n\r\nexport function WalletScreen({ onNavigate }: { onNavigate: (s: string) => void }) {\r\n  const [filter, setFilter] = useState('All');\r\n  const [showWithdraw, setShowWithdraw] = useState(false);\r\n  const [withdrawStep, setWithdrawStep] = useState(1);\r\n  const [withdrawAmount, setWithdrawAmount] = useState('');\r\n  const { haptic } = useHaptics();\r\n\r\n  const filtered = TRANSACTIONS.filter(t => {\r\n    if (filter === 'Earned') return t.type === 'credit';\r\n    if (filter === 'Spent')  return t.type === 'debit';\r\n    if (filter === 'Pending') return t.status === 'Pending';\r\n    return true;\r\n  });\r\n\r\n  return (\r\n    <div style={{ paddingBottom: 80 }}>\r\n      <TopBar title=\"Wallet\" />\r\n\r\n      {/* Balance card */}\r\n      <div style={{ padding: '16px 20px 20px' }}>\r\n        <div className=\"wallet-balance\">\r\n          <div style={{ fontSize: '0.875rem', opacity: 0.75, marginBottom: 4, position: 'relative', zIndex: 1 }}>Available Balance</div>\r\n          <div className=\"wallet-amount\">Γéª58,250</div>\r\n          <div style={{ display: 'flex', gap: 20, marginTop: 16, position: 'relative', zIndex: 1 }}>\r\n            <div>\r\n              <div style={{ fontSize: '0.75rem', opacity: 0.65 }}>Pending Escrow</div>\r\n              <div style={{ fontWeight: 700, fontSize: '1rem' }}>Γéª15,000</div>\r\n            </div>\r\n            <div style={{ width: 1, background: 'rgba(255,255,255,0.2)' }} />\r\n            <div>\r\n              <div style={{ fontSize: '0.75rem', opacity: 0.65 }}>Lifetime Earnings</div>\r\n              <div style={{ fontWeight: 700, fontSize: '1rem' }}>Γéª284,500</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Action buttons */}\r\n      <div style={{ padding: '0 20px 20px', display: 'flex', gap: 12 }}>\r\n        <button\r\n          className=\"btn btn-primary btn-full btn-bounce\"\r\n          style={{ borderRadius: 'var(--radius-md)' }}\r\n          onClick={() => { haptic('medium'); setShowWithdraw(true); }}\r\n        >\r\n          Withdraw\r\n        </button>\r\n        <button\r\n          className=\"btn btn-secondary btn-full\"\r\n          style={{ borderRadius: 'var(--radius-md)' }}\r\n          onClick={() => { haptic('light'); onNavigate('add-funds'); }}\r\n        >\r\n          Add Funds\r\n        </button>\r\n      </div>\r\n\r\n      {/* Filter tabs */}\r\n      <div className=\"filter-tabs\">\r\n        {FILTER_TABS.map(tab => (\r\n          <button\r\n            key={tab}\r\n            id={`wallet-tab-${tab.toLowerCase()}`}\r\n            className={`filter-tab ${filter === tab ? 'active' : ''}`}\r\n            onClick={() => { haptic('selection'); setFilter(tab); }}\r\n          >\r\n            {tab}\r\n          </button>\r\n        ))}\r\n      </div>\r\n\r\n      {/* Transaction list */}\r\n      <div style={{ padding: '0 20px' }}>\r\n        <div style={{ fontWeight: 700, marginBottom: 12 }}>Transaction History</div>\r\n        {filtered.map(tx => (\r\n          <div key={tx.id} style={{\r\n            display: 'flex', gap: 12, alignItems: 'center',\r\n            padding: '14px 0', borderBottom: '1px solid var(--separator)',\r\n          }}>\r\n            <div style={{\r\n              width: 44, height: 44, borderRadius: '50%',\r\n              background: tx.type === 'credit' ? '#D1FAE5' : '#FEE2E2',\r\n              display: 'flex', alignItems: 'center', justifyContent: 'center',\r\n              flexShrink: 0,\r\n              color: tx.type === 'credit' ? '#065F46' : '#DC2626',\r\n            }}>\r\n              <StickyIcon src={tx.icon} size={22} />\r\n            </div>\r\n            <div style={{ flex: 1 }}>\r\n              <div style={{ fontWeight: 600, fontSize: '0.9375rem', marginBottom: 2 }}>{tx.desc}</div>\r\n              <div style={{ fontSize: '0.75rem', color: 'var(--text-muted)' }}>{tx.date}</div>\r\n            </div>\r\n            <div style={{ textAlign: 'right' }}>\r\n              <div style={{\r\n                fontWeight: 700, fontSize: '1rem',\r\n                color: tx.type === 'credit' ? 'var(--soft-green)' : 'var(--status-danger)',\r\n              }}>\r\n                {tx.amount}\r\n              </div>\r\n              <div style={{\r\n                fontSize: '0.6875rem', fontWeight: 600, marginTop: 2,\r\n                color: tx.status === 'Completed' ? 'var(--soft-green)' :\r\n                       tx.status === 'Pending' ? 'var(--status-warning)' : 'var(--text-muted)',\r\n              }}>\r\n                {tx.status}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        ))}\r\n      </div>\r\n\r\n      {/* Withdraw modal */}\r\n      {showWithdraw && (\r\n        <div style={{\r\n          position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.5)', zIndex: 200,\r\n          display: 'flex', alignItems: 'flex-end',\r\n        }} onClick={() => { setShowWithdraw(false); setWithdrawStep(1); }}>\r\n          <div\r\n            style={{ background: 'var(--bg-primary)', borderRadius: '24px 24px 0 0', width: '100%', padding: '24px 20px 40px', maxWidth: 430, margin: '0 auto' }}\r\n            onClick={e => e.stopPropagation()}\r\n          >\r\n            {withdrawStep === 1 && (\r\n              <>\r\n                <div style={{ fontWeight: 700, fontSize: '1.125rem', marginBottom: 6 }}>Withdraw Funds</div>\r\n                <div style={{ fontSize: '0.875rem', color: 'var(--text-muted)', marginBottom: 20 }}>\r\n                  Available: <strong style={{ color: 'var(--text-primary)' }}>Γéª58,250</strong> ┬╖ Min: Γéª1,000\r\n                </div>\r\n                <div className=\"input-group\">\r\n                  <label className=\"input-label\">Amount</label>\r\n                  <div style={{ display: 'flex', alignItems: 'center' }}>\r\n                    <span style={{ padding: '14px 12px', background: 'var(--bg-elevated)', border: '1.5px solid var(--separator)', borderRight: 'none', borderRadius: 'var(--radius-md) 0 0 var(--radius-md)', fontWeight: 700 }}>Γéª</span>\r\n                    <input\r\n                      type=\"number\"\r\n                      className=\"input-field\"\r\n                      style={{ borderRadius: '0 var(--radius-md) var(--radius-md) 0' }}\r\n                      placeholder=\"10,000\"\r\n                      value={withdrawAmount}\r\n                      onChange={e => setWithdrawAmount(e.target.value)}\r\n                    />\r\n                  </div>\r\n                </div>\r\n                <button className=\"btn btn-primary btn-full\" onClick={() => { haptic('medium'); setWithdrawStep(2); }} style={{ borderRadius: 'var(--radius-md)', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 6 }}>\r\n                  Next <MdArrowForward size={18} />\r\n                </button>\r\n              </>\r\n            )}\r\n\r\n            {withdrawStep === 2 && (\r\n              <>\r\n                <div style={{ fontWeight: 700, fontSize: '1.125rem', marginBottom: 16 }}>Confirm Account</div>\r\n                <div style={{ background: 'var(--bg-elevated)', borderRadius: 'var(--radius-md)', padding: '16px', marginBottom: 20 }}>\r\n                  <div style={{ fontSize: '0.875rem', color: 'var(--text-muted)', marginBottom: 4 }}>Withdrawing to</div>\r\n                  <div style={{ fontWeight: 700 }}>GTBank ┬╖┬╖┬╖┬╖ 0789</div>\r\n                  <div style={{ fontSize: '0.875rem', color: 'var(--text-secondary)' }}>Ayomide Okafor</div>\r\n                </div>\r\n                <p style={{ fontSize: '0.8125rem', color: 'var(--text-muted)', marginBottom: 16 }}>\r\n                  Withdrawals process in 1ΓÇô2 business days.\r\n                </p>\r\n                <button className=\"btn btn-primary btn-full btn-bounce\" onClick={() => { haptic('success'); setShowWithdraw(false); setWithdrawStep(1); }} style={{ borderRadius: 'var(--radius-md)', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 6 }}>\r\n                  Confirm Withdrawal <MdCheck size={18} />\r\n                </button>\r\n              </>\r\n            )}\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\user\\Desktop\\Keep\\Antigravity Experiments\\helpa\\vite.config.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
